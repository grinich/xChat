{
  "name": "xchat",
  "description": "Keyboard-first, full-screen enhancer for X (Twitter) DMs",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "zip": "wxt zip",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wxt": "^0.20.6"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "esbuild@0.27.7": true,
    "spawn-sync@1.0.15": true
  }
}
